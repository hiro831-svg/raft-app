{
  "expo": {
    "name": "CraftShare",
    "slug": "craftshare",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.craftshare.app"
    },
    "android": {
      "package": "com.craftshare.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker"
    ],
    "scheme": "craftshare"
  }
}
